{
  "name": "codebattle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.5.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
